# Copy this file to secrets.zsh and fill in your actual values
# secrets.zsh is gitignored and will not be committed

# jira cli - get your token from https://id.atlassian.com/manage-profile/security/api-tokens
export JIRA_API_TOKEN=your_jira_api_token_here

# spotify-player - get your client_id from https://developer.spotify.com/dashboard
export SPOTIFY_CLIENT_ID=your_spotify_client_id_here
