#!/usr/bin/env bash

set -euo pipefail

dir="${1:-$PWD}"
target="${dir##*/}"
target="${target//[^[:alnum:]_-]/_}"
session="=$target"

session_id() {
  tmux display-message -p -t "$session" '#{session_id}'
}

has_window() {
  tmux list-windows -t "$1" -F '#W' | grep -Fxq "$2"
}

ensure_window() {
  local target="$1"
  local name="$2"
  local command="${3:-}"

  has_window "$target" "$name" && return 0

  if [[ -n "$command" ]]; then
    tmux new-window -d -t "$target" -n "$name" -c "$dir" "$command"
  else
    tmux new-window -d -t "$target" -n "$name" -c "$dir"
  fi
}

if tmux has-session -t "$session" 2>/dev/null; then
  target="$(session_id)"
  ensure_window "$target" nvim nvim
  ensure_window "$target" term
  ensure_window "$target" git lazygit
else
  tmux new-session -d -s "$target" -n nvim -c "$dir" nvim
  target="$(session_id)"
  tmux new-window -d -t "$target" -n term -c "$dir"
  tmux new-window -d -t "$target" -n git -c "$dir" lazygit
fi

tmux select-window -t "$target:nvim"

if [[ -z "${TMUX:-}" ]]; then
  tmux attach -t "$target"
else
  tmux switch-client -t "$target"
fi
